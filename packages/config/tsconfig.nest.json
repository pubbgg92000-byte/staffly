{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictBindCallApply": false,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "outDir": "./dist",
    "removeComments": true
  }
}
