# Copy to .env and adjust. Never commit .env (see .gitignore).

# Postgres — defaults match infra/docker-compose.dev.yml
DATABASE_URL="postgresql://staffly:staffly_dev_password@localhost:5432/staffly?schema=public"

# Redis — cache + BullMQ queues
REDIS_URL="redis://localhost:6379"

# API
PORT=4000
NODE_ENV=development

# Auth (Batch 3)
JWT_SECRET="replace-me-with-a-long-random-string"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
COOKIE_DOMAIN="localhost"
APP_DATA_ENC_KEY="replace-me-with-a-32-byte-base64-key"

# Email — Mailhog in dev
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="Staffly <no-reply@staffly.local>"

# Object storage — MinIO in dev
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=staffly-dev
S3_ACCESS_KEY_ID=staffly
S3_SECRET_ACCESS_KEY=staffly_dev_password

# Portal hosts (used to build absolute links in emails)
ADMIN_BASE_URL=http://localhost:3000
EMPLOYEE_BASE_URL=http://localhost:3001
