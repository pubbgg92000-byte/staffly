# Copy to .env and adjust. Never commit .env (see .gitignore).
#
# This file mirrors the validated schema in src/infra/config/env.ts — every
# var below is actually read by the app. (Vars that env.ts doesn't validate
# would be silently ignored, so they are intentionally not listed here.)

# ─── Postgres ──────────────────────────────────────────────────────────
# Dev default matches infra/docker-compose.dev.yml. Prod demo points at the
# loopback-bound PG18 from infra/docker-compose.prod.yml.
DATABASE_URL="postgresql://staffly:staffly_dev_password@localhost:5433/staffly?schema=public"

# ─── Redis (optional) ──────────────────────────────────────────────────
# Currently unused by the app (reserved for the Phase F email queue). Leave
# unset for the demo.
# REDIS_URL="redis://localhost:6379"

# ─── API ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth / tokens ─────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 chars. Generate: openssl rand -base64 36
JWT_SECRET="replace-me-with-a-long-random-string-min-32-chars"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
REMEMBER_ME_REFRESH_TTL_SECONDS=2592000
PASSWORD_RESET_TTL_SECONDS=3600
INVITE_TOKEN_TTL_SECONDS=604800
TWO_FACTOR_CHALLENGE_TTL_SECONDS=300

# Base URL used to build reset/invite links in outbound email.
# PROD BOOT GUARD: a localhost/127.0.0.1 value refuses to boot when
# NODE_ENV=production (emailed links would be unusable).
APP_BASE_URL="http://localhost:3000"

# ─── Cookies / CORS ────────────────────────────────────────────────────
# Dev: localhost. Prod demo: ".staffly.av.online" so the auth cookie is shared
# across the portal + api subdomains (and `secure` flips on automatically when
# NODE_ENV=production).
# PROD BOOT GUARD: the "localhost" default refuses to boot when
# NODE_ENV=production (browsers would never send the auth cookies).
COOKIE_DOMAIN="localhost"
# Comma-separated origin allowlist for credentialed CORS. Prod demo:
# "https://admin.staffly.av.online,https://staffly.av.online"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── Object storage (S3 / Cloudflare R2) ───────────────────────────────
# Dev (MinIO):    endpoint http://localhost:9000, region us-east-1
# Prod demo (R2): endpoint https://<acct>.r2.cloudflarestorage.com, region "auto"
# A complete S3 configuration is required when NODE_ENV=production.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="staffly-dev"
S3_ACCESS_KEY_ID="staffly"
S3_SECRET_ACCESS_KEY="staffly_dev_password"
S3_PRESIGN_TTL_SECONDS=900

# ─── Observability ─────────────────────────────────────────────────────
# Sentry DSN for the API. Leave unset in dev/test — init becomes a no-op.
# SENTRY_DSN="https://<key>@<org>.ingest.sentry.io/<project>"

# ─── Email delivery ────────────────────────────────────────────────────
# Provider-agnostic outbound mail (invites, password reset, welcome, leave
# decisions). EMAIL_PROVIDER selects the adapter; an unset/missing credential
# for the chosen provider falls back to the "log" adapter outside production.
# Production refuses an incomplete provider configuration; EMAIL_PROVIDER=log
# must be explicit to disable delivery intentionally. Sends are fire-and-forget
# after boot — a mail outage never breaks the triggering request.
#
#   log     — default. Logs the message, sends nothing. (dev/test/CI/no creds)
#   smtp    — any SMTP server. In dev point at Mailhog (infra/docker-compose.dev.yml):
#               EMAIL_PROVIDER=smtp  SMTP_HOST=localhost  SMTP_PORT=1025  SMTP_SECURE=false
#             View captured mail at http://localhost:8025 (API: /api/v2/messages).
#   resend  — Resend HTTP API. Prod example:
#               EMAIL_PROVIDER=resend  RESEND_API_KEY=re_...  EMAIL_FROM="Staffly <no-reply@staffly.av.online>"
#   mailgun — Mailgun HTTP API:
#               EMAIL_PROVIDER=mailgun  MAILGUN_API_KEY=...  MAILGUN_DOMAIN=mg.staffly.av.online
EMAIL_PROVIDER=log
# PROD BOOT GUARD: the dev default (…@staffly.local) refuses to boot when
# NODE_ENV=production — set a sender on a domain you can deliver from.
EMAIL_FROM="Staffly <no-reply@staffly.local>"

# SMTP (provider=smtp)
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Resend (provider=resend)
RESEND_API_KEY=

# Mailgun (provider=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net

# ─── Demo seed (db:seed:demo / deploy/reset-demo.sh) ───────────────────
# Selects which profile the demo seed renders into the SAME pinned
# `staffly-demo` org. Valid values: `us` (default — Acme Corporation,
# America/New_York, USD, US public holidays) or `india` (Bharat Tech
# Solutions Pvt Ltd, Asia/Kolkata, INR, India public holidays). Tenant
# identity (slug + pinned org id) is identical across profiles — only
# descriptive/locale data swaps.
# DEMO_PROFILE=us
#
# Demo login passwords. The seed loads this file (so values set here work
# even under `tsx`) and REFUSES to run if any admin password below is
# missing or shorter than 8 chars — it will NOT generate unknown random
# passwords (RC-01). The employee account uses the published default
# `Employee@123` unless DEMO_EMPLOYEE_PASSWORD is set. Required:
# DEMO_SUPERADMIN_PASSWORD=change-me-strong
# DEMO_HR_PASSWORD=change-me-strong
# DEMO_MANAGER_PASSWORD=change-me-strong
# Optional:
# DEMO_EMPLOYEE_PASSWORD=Employee@123
