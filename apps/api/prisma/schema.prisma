// Staffly — Identity, Tenancy & RBAC (Sprint 0 Batch 2).
//
// Source of truth: docs/02-database-design.md § 2.1.
// Conventions: snake_case tables / columns, UUIDv7 PKs (Postgres 18 native uuidv7()),
// timestamptz, soft delete via deleted_at where applicable.
//
// Domain modules (employees, attendance, leave, …) are added in their own sprints.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum OrgPlan {
  trial
  starter
  growth
  enterprise

  @@map("org_plan")
}

enum OrgStatus {
  active
  suspended
  cancelled

  @@map("org_status")
}

enum UserStatus {
  invited
  active
  disabled

  @@map("user_status")
}

enum Portal {
  admin
  employee

  @@map("portal")
}

enum PermissionScope {
  global
  team
  self
  assigned

  @@map("permission_scope")
}

enum NotificationPriority {
  low
  normal
  high

  @@map("notification_priority")
}

enum EmployeeStatus {
  invited
  active
  on_leave
  suspended
  offboarded

  @@map("employee_status")
}

enum EmploymentType {
  full_time
  part_time
  intern
  contractor
  consultant

  @@map("employment_type")
}

enum WorkMode {
  onsite
  hybrid
  remote

  @@map("work_mode")
}

enum Gender {
  male
  female
  non_binary
  prefer_not_to_say
  other

  @@map("gender")
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
  other

  @@map("marital_status")
}

enum AttendanceStatus {
  present
  half_day
  absent
  on_leave
  holiday
  weekoff

  @@map("attendance_status")
}

enum RegularizationStatus {
  pending
  approved
  rejected
  cancelled

  @@map("regularization_status")
}

// ─── Organizations ──────────────────────────────────────────────────────────

model Organization {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name            String    @db.VarChar(120)
  slug            String    @unique @db.VarChar(60)
  legalName       String?   @map("legal_name") @db.VarChar(180)
  domain          String?   @db.VarChar(180)
  logoUrl         String?   @map("logo_url")
  primaryColor    String    @default("#0F172A") @map("primary_color") @db.VarChar(9)
  timezone        String    @default("Etc/UTC") @db.VarChar(64)
  locale          String    @default("en-US") @db.VarChar(16)
  currency        String    @default("USD") @db.Char(3)
  weekStart       Int       @default(1) @map("week_start") @db.SmallInt
  billingEmail    String?   @map("billing_email") @db.VarChar(254)
  plan            OrgPlan   @default(trial)
  status          OrgStatus @default(active)
  trialEndsAt     DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  settingsVersion Int       @default(1) @map("settings_version")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  settings                  OrgSetting[]
  users                     User[]
  refreshTokens             RefreshToken[]
  roles                     Role[]
  rolePermissions           RolePermission[]
  userRoles                 UserRole[]
  auditLogs                 AuditLog[]
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  employees                 Employee[]
  departments               Department[]
  designations              Designation[]
  locations                 Location[]
  attendancePolicies        AttendancePolicy[]
  attendanceRecords         AttendanceRecord[]
  attendanceRegularizations AttendanceRegularization[]

  @@unique([domain])
  @@index([status])
  @@index([plan])
  @@map("organizations")
}

model OrgSetting {
  organizationId String   @map("organization_id") @db.Uuid
  key            String   @db.VarChar(100)
  value          Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, key])
  @@map("org_settings")
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id                        String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId            String     @map("organization_id") @db.Uuid
  email                     String     @db.VarChar(254)
  emailVerifiedAt           DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  passwordHash              String?    @map("password_hash")
  status                    UserStatus @default(invited)
  inviteTokenHash           String?    @map("invite_token_hash") @db.VarChar(128)
  inviteTokenExpiresAt      DateTime?  @map("invite_token_expires_at") @db.Timestamptz(6)
  twoFactorEnabled          Boolean    @default(false) @map("two_factor_enabled")
  twoFactorSecretEnc        String?    @map("two_factor_secret_enc")
  twoFactorRecoveryCodesEnc String?    @map("two_factor_recovery_codes_enc")
  lastLoginAt               DateTime?  @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp               String?    @map("last_login_ip") @db.Inet
  failedLoginCount          Int        @default(0) @map("failed_login_count")
  lockedUntil               DateTime?  @map("locked_until") @db.Timestamptz(6)
  defaultPortal             Portal     @default(employee) @map("default_portal")
  preferences               Json       @default("{}") @db.JsonB
  createdAt                 DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                 DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdBy                 String?    @map("created_by") @db.Uuid
  updatedBy                 String?    @map("updated_by") @db.Uuid

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  refreshTokens           RefreshToken[]
  userRoles               UserRole[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@unique([organizationId, email])
  @@unique([email])
  @@index([organizationId, status])
  @@index([inviteTokenHash])
  @@map("users")
}

model RefreshToken {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.Char(64)
  parentId       String?   @map("parent_id") @db.Uuid
  userAgent      String?   @map("user_agent")
  ipAddress      String?   @map("ip_address") @db.Inet
  issuedAt       DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokeReason   String?   @map("revoke_reason") @db.VarChar(40)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       RefreshToken?  @relation("RefreshTokenChain", fields: [parentId], references: [id], onDelete: SetNull)
  children     RefreshToken[] @relation("RefreshTokenChain")

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── RBAC ───────────────────────────────────────────────────────────────────

model Role {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  key            String    @db.VarChar(40)
  name           String    @db.VarChar(80)
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, key])
  @@map("roles")
}

/// Global catalog of permission keys. Not tenant-scoped.
model Permission {
  key         String   @id @db.VarChar(80)
  resource    String   @db.VarChar(40)
  action      String   @db.VarChar(40)
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  organizationId String          @map("organization_id") @db.Uuid
  roleId         String          @map("role_id") @db.Uuid
  permissionKey  String          @map("permission_key") @db.VarChar(80)
  scope          PermissionScope @default(global)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionKey], references: [key], onDelete: Restrict)

  @@id([roleId, permissionKey])
  @@index([organizationId])
  @@map("role_permissions")
}

model UserRole {
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy     String?  @map("assigned_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([organizationId])
  @@map("user_roles")
}

// ─── Audit & Notifications ──────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorIp        String?  @map("actor_ip") @db.Inet
  action         String   @db.VarChar(80)
  resourceType   String   @map("resource_type") @db.VarChar(40)
  resourceId     String?  @map("resource_id") @db.Uuid
  before         Json?    @db.JsonB
  after          Json?    @db.JsonB
  metadata       Json     @default("{}") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([action])
  @@map("audit_logs")
}

model Notification {
  id             String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  templateId     String               @map("template_id") @db.VarChar(40)
  payload        Json                 @default("{}") @db.JsonB
  linkTo         String?              @map("link_to")
  priority       NotificationPriority @default(normal)
  readAt         DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String?              @map("created_by") @db.Uuid
  updatedBy      String?              @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  organizationId String  @map("organization_id") @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  templateId     String  @map("template_id") @db.VarChar(40)
  emailEnabled   Boolean @default(true) @map("email_enabled")
  inappEnabled   Boolean @default(true) @map("inapp_enabled")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, templateId])
  @@index([organizationId])
  @@map("notification_preferences")
}

// ─── Org structure ──────────────────────────────────────────────────────────

model Department {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(100)
  code           String?   @db.VarChar(20)
  parentId       String?   @map("parent_id") @db.Uuid
  headEmployeeId String?   @map("head_employee_id") @db.Uuid
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Department[] @relation("DepartmentTree")
  employees    Employee[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model Designation {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(120)
  level          Int?      @db.SmallInt
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("designations")
}

model Location {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(120)
  code           String?   @db.VarChar(20)
  addressLine1   String?   @map("address_line1") @db.VarChar(180)
  addressLine2   String?   @map("address_line2") @db.VarChar(180)
  city           String?   @db.VarChar(80)
  state          String?   @db.VarChar(80)
  country        String?   @db.Char(2)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  timezone       String    @default("Etc/UTC") @db.VarChar(64)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("locations")
}

model Employee {
  id               String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  userId           String?        @unique @map("user_id") @db.Uuid
  employeeCode     String         @map("employee_code") @db.VarChar(32)
  firstName        String         @map("first_name") @db.VarChar(60)
  middleName       String?        @map("middle_name") @db.VarChar(60)
  lastName         String         @map("last_name") @db.VarChar(60)
  displayName      String         @map("display_name") @db.VarChar(120)
  personalEmail    String?        @map("personal_email") @db.VarChar(254)
  workEmail        String         @map("work_email") @db.VarChar(254)
  mobilePhoneE164  String?        @map("mobile_phone_e164") @db.VarChar(20)
  dateOfBirth      DateTime?      @map("date_of_birth") @db.Date
  gender           Gender?
  nationality      String?        @db.Char(2)
  maritalStatus    MaritalStatus? @map("marital_status")
  bloodGroup       String?        @map("blood_group") @db.VarChar(3)
  profilePhotoUrl  String?        @map("profile_photo_url")
  status           EmployeeStatus @default(invited)
  joinedOn         DateTime?      @map("joined_on") @db.Date
  confirmedOn      DateTime?      @map("confirmed_on") @db.Date
  terminatedOn     DateTime?      @map("terminated_on") @db.Date
  departmentId     String?        @map("department_id") @db.Uuid
  designationId    String?        @map("designation_id") @db.Uuid
  locationId       String?        @map("location_id") @db.Uuid
  managerId        String?        @map("manager_id") @db.Uuid
  employmentType   EmploymentType @default(full_time) @map("employment_type")
  workMode         WorkMode       @default(onsite) @map("work_mode")
  timezoneOverride String?        @map("timezone_override") @db.VarChar(64)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdBy        String?        @map("created_by") @db.Uuid
  updatedBy        String?        @map("updated_by") @db.Uuid

  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department                Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation               Designation?               @relation(fields: [designationId], references: [id], onDelete: SetNull)
  location                  Location?                  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  manager                   Employee?                  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports                   Employee[]                 @relation("EmployeeManager")
  attendanceRecords         AttendanceRecord[]
  attendanceRegularizations AttendanceRegularization[]

  @@unique([organizationId, employeeCode])
  @@unique([organizationId, workEmail])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([organizationId, managerId])
  @@index([organizationId, displayName])
  @@map("employees")
}

// ─── Attendance ─────────────────────────────────────────────────────────────

model AttendancePolicy {
  id                         String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId             String    @map("organization_id") @db.Uuid
  name                       String    @db.VarChar(80)
  isDefault                  Boolean   @default(false) @map("is_default")
  workDays                   Int[]     @default([1, 2, 3, 4, 5]) @map("work_days") @db.SmallInt
  expectedHoursPerDay        Decimal   @default(8.00) @map("expected_hours_per_day") @db.Decimal(4, 2)
  dayStartTime               String    @default("09:00") @map("day_start_time") @db.VarChar(8)
  dayEndTime                 String    @default("18:00") @map("day_end_time") @db.VarChar(8)
  graceMinutesLate           Int       @default(15) @map("grace_minutes_late") @db.SmallInt
  halfDayThresholdHours      Decimal   @default(4.00) @map("half_day_threshold_hours") @db.Decimal(4, 2)
  regularizationWindowDays   Int       @default(14) @map("regularization_window_days") @db.SmallInt
  autoCloseAtMinutesAfterEnd Int?      @default(120) @map("auto_close_at_minutes_after_end") @db.SmallInt
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy                  String?   @map("created_by") @db.Uuid
  updatedBy                  String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, isDefault])
  @@map("attendance_policies")
}

model AttendanceRecord {
  id                String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  employeeId        String           @map("employee_id") @db.Uuid
  attendanceDate    DateTime         @map("attendance_date") @db.Date
  checkInAt         DateTime?        @map("check_in_at") @db.Timestamptz(6)
  checkOutAt        DateTime?        @map("check_out_at") @db.Timestamptz(6)
  checkInIp         String?          @map("check_in_ip") @db.Inet
  checkOutIp        String?          @map("check_out_ip") @db.Inet
  checkInUserAgent  String?          @map("check_in_user_agent")
  checkOutUserAgent String?          @map("check_out_user_agent")
  workedMinutes     Int?             @map("worked_minutes")
  status            AttendanceStatus @default(absent)
  isLate            Boolean          @default(false) @map("is_late")
  isRegularized     Boolean          @default(false) @map("is_regularized")
  regularizationId  String?          @map("regularization_id") @db.Uuid
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         String?          @map("created_by") @db.Uuid
  updatedBy         String?          @map("updated_by") @db.Uuid

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  regularization AttendanceRegularization? @relation("RegularizationApplied", fields: [regularizationId], references: [id], onDelete: SetNull)

  @@unique([employeeId, attendanceDate])
  @@index([organizationId, attendanceDate])
  @@index([organizationId, status, attendanceDate])
  @@map("attendance_records")
}

model AttendanceRegularization {
  id                  String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  employeeId          String               @map("employee_id") @db.Uuid
  attendanceDate      DateTime             @map("attendance_date") @db.Date
  requestedCheckInAt  DateTime?            @map("requested_check_in_at") @db.Timestamptz(6)
  requestedCheckOutAt DateTime?            @map("requested_check_out_at") @db.Timestamptz(6)
  reason              String
  status              RegularizationStatus @default(pending)
  decidedBy           String?              @map("decided_by") @db.Uuid
  decidedAt           DateTime?            @map("decided_at") @db.Timestamptz(6)
  decisionComment     String?              @map("decision_comment")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy           String?              @map("created_by") @db.Uuid
  updatedBy           String?              @map("updated_by") @db.Uuid

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee       Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  appliedRecords AttendanceRecord[] @relation("RegularizationApplied")

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([employeeId, attendanceDate])
  @@map("attendance_regularizations")
}
