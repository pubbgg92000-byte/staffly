{
  "extends": "@staffly/config/tsconfig.nest.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "prisma/seed.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
